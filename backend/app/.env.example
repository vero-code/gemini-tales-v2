# INFRASTRUCTURE
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id
GOOGLE_CLOUD_LOCATION=your_google_cloud_location


# CONFIGURATION
MODEL_NAME=gemini-3.1-pro-preview
MODEL_NAME_FLASH=gemini-3.1-flash-lite-preview
MODEL_ID=gemini-live-2.5-flash-native-audio
GEMINI_API_KEY=your_gemini_api_key
VITE_MODEL_ID_IMAGE=gemini-3.1-flash-image-preview
VIDEO_MODEL_ID=veo-3.1-generate-preview

# ENVIRONMENT/A2A
PYTHONPATH=.;shared
# DEPLOY
RESEARCHER_AGENT_CARD_URL=your_researcher_agent_card_url
JUDGE_AGENT_CARD_URL=your_judge_agent_card_url
BUILDER_AGENT_CARD_URL=your_builder_agent_card_url
AGENT_SERVER_URL=your_agent_server_url
PORT=8000

# APP (main.py)
# AGENT_NAME=your_agent_name  # optional: auto-discovered from AGENT_SERVER_URL if not set